{
  "cleanUrls": true,
  "rewrites": [
    { "source": "/trial-signup", "destination": "/pages/trial-signup.html" },
    { "source": "/login",        "destination": "/pages/login.html" },
    { "source": "/register",     "destination": "/pages/trial-signup.html" },
    { "source": "/dashboard",    "destination": "/pages/dashboard.html" },
    { "source": "/admin",        "destination": "/pages/admin.html" },
    { "source": "/faq",          "destination": "/pages/faq.html" },
    { "source": "/about",        "destination": "/pages/about.html" },
    { "source": "/terms",        "destination": "/pages/terms.html" },
    { "source": "/privacy",      "destination": "/pages/privacy.html" },
    { "source": "/refund",       "destination": "/pages/refund.html" },
    { "source": "/contact",      "destination": "/pages/contact.html" },
    { "source": "/form/:path*",  "destination": "/pages/public-form.html" }
  ]
}
