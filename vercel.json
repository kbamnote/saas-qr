{
  "routes": [
    { "src": "/faq",          "dest": "/pages/faq.html" },
    { "src": "/about",        "dest": "/pages/about.html" },
    { "src": "/login",        "dest": "/pages/login.html" },
    { "src": "/trial-signup", "dest": "/pages/trial-signup.html" },
    { "src": "/register",     "dest": "/pages/trial-signup.html" },
    { "src": "/dashboard",    "dest": "/pages/dashboard.html" },
    { "src": "/admin",        "dest": "/pages/admin.html" },
    { "src": "/terms",        "dest": "/pages/terms.html" },
    { "src": "/privacy",      "dest": "/pages/privacy.html" },
    { "src": "/refund",       "dest": "/pages/refund.html" },
    { "src": "/contact",      "dest": "/pages/contact.html" },
